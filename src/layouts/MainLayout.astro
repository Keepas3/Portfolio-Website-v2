---
// src/layouts/MainLayout.astro
const { title = "BryanDev | Portfolio" } = Astro.props;
import '../styles/global.css'; // If you still have global styles
import Navbar from '../components/Navbar.astro';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link href='https://cdn.jsdelivr.net/npm/boxicons@2.0.5/css/boxicons.min.css' rel='stylesheet'>
        <link rel="icon" type="image/png" href="/favicon.png?v=1">
        <title>{title}</title>
    </head>
    <body class="bg-slate-50 text-slate-900 font-sans"> <Navbar /> <slot />
         <footer class="py-10 bg-slate-900 text-white text-center">
            <p class="text-xl font-bold mb-4">BryanDev</p>
            <div class="flex justify-center gap-6 mb-4 text-2xl">
                <a href="https://github.com/Keepas3"
                target="_blank" 
                rel="noopener noreferrer" 
                class="hover:text-orange-500 transition-colors"><i class='bx bxl-github'></i></a>
                <a href="https://www.linkedin.com/in/bryan-fung-a2a089256/" target="_blank" rel="noopener noreferrer" class="hover:text-blue-500 transition-colors"><i class='bx bxl-linkedin'></i></a>
            </div>
            <p class="text-sm opacity-70">© {new Date().getFullYear()} BryanDev. All rights reserved</p>
        </footer>
    </body>
</html>