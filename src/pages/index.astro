<script>
  const modal = document.querySelector('#project-modal') as HTMLDialogElement;
  const projectCards = document.querySelectorAll('.project-trigger');
  const closeButtons = document.querySelectorAll('.close-modal');
  const videoSwitcher = document.querySelector('#video-switcher') as HTMLElement;
  const tabButtons = document.querySelectorAll('.video-tab-btn');

  const modalTitle = document.querySelector('#modal-title');
  const modalDesc = document.querySelector('#modal-description');
  const modalVideo = document.querySelector('#modal-video') as HTMLVideoElement;
  const modalVideoSource = document.querySelector('#modal-video source') as HTMLSourceElement;
  const modalGithub = document.querySelector('#modal-github') as HTMLAnchorElement;

  // We'll store the currently active card here so the tabs know where to pull data from
  let activeCard: Element | null = null;

  projectCards.forEach((card) => {
    card.addEventListener('click', () => {
      activeCard = card; // Set the current context
      
      const title = card.getAttribute('data-title') || '';
      const fullDesc = card.getAttribute('data-full-desc') || '';
      const githubLink = card.getAttribute('data-link') || '#';
      
      // Check if this project has the "Ecosystem" videos
      const videoBot = card.getAttribute('data-video-bot');
      const videoWeb = card.getAttribute('data-video-web');
      const defaultVideo = card.getAttribute('data-video') || videoBot || '';

      // 1. Toggle Switcher Visibility
      if (videoSwitcher) {
        // Only show the tabs if BOTH video types exist
        videoSwitcher.style.display = (videoBot && videoWeb) ? 'flex' : 'none';
      }

      // 2. Inject basic data
      if (modalTitle) modalTitle.textContent = title;
      if (modalDesc) modalDesc.textContent = fullDesc;
      if (modalGithub) modalGithub.href = githubLink;

      // 3. Load the default video
      if (modalVideoSource && modalVideo) {
        modalVideoSource.src = defaultVideo;
        modalVideo.load();
      }

      modal.showModal();
    });
  });

  // 4. Improved Tab Switcher Logic
  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      if (!activeCard) return;

      const type = btn.getAttribute('data-type');
      const videoSrc = type === 'bot' 
          ? activeCard.getAttribute('data-video-bot') 
          : activeCard.getAttribute('data-video-web');

      if (modalVideoSource && modalVideo && videoSrc) {
          modalVideoSource.src = videoSrc;
          modalVideo.load();
      }

      // Visual update for the buttons
      tabButtons.forEach(b => b.classList.remove('bg-white/40', 'border-white/60'));
      btn.classList.add('bg-white/40', 'border-white/60');
    });
  });

  // 5. Close & Cleanup
  closeButtons.forEach((button) => {
    button.addEventListener('click', () => {
      modal.close();
      if (modalVideo) modalVideo.pause();
    });
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
        modal.close();
        if (modalVideo) modalVideo.pause();
    }
  });
</script>