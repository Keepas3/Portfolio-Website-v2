<script>
  // 1. SELECTORS
  const modal = document.querySelector('#project-modal') as HTMLDialogElement;
  const modalVideo = document.querySelector('#modal-video') as HTMLVideoElement;
  const modalVideoSource = document.querySelector('#modal-video source') as HTMLSourceElement;
  const modalGalleryContainer = document.querySelector('#modal-gallery-container') as HTMLElement;
  const modalGallery = document.querySelector('#modal-gallery') as HTMLElement;
  
  const projectCards = document.querySelectorAll('.project-trigger');
  const closeButtons = document.querySelectorAll('.close-modal');
  
  const modalTitle = document.querySelector('#modal-title');
  const modalDesc = document.querySelector('#modal-description');
  const modalGithub = document.querySelector('#modal-github') as HTMLAnchorElement;

  const ecosystemTabs = document.querySelector('#ecosystem-tabs') as HTMLElement;
  const showVideoBtn = document.querySelector('#show-video');
  const showGalleryBtn = document.querySelector('#show-gallery');
  const prevBtn = document.querySelector('#prev-img');
  const nextBtn = document.querySelector('#next-img');

  let activeCard: Element | null = null;

  // 2. THE MAIN OPEN LOGIC
  projectCards.forEach((card) => {
    card.addEventListener('click', () => {
      activeCard = card; 
      
      // Always reset to Video view when opening a new project
      showView('video');

      // Check for images to show/hide the Gallery toggle
      const gallerySource = card.querySelector('.hidden-gallery');
      const hasImages = gallerySource ? gallerySource.querySelectorAll('img').length > 0 : false;
      const galleryHTML = gallerySource?.innerHTML || '';
      
      if (showGalleryBtn instanceof HTMLElement) {
        showGalleryBtn.style.display = hasImages ? 'flex' : 'none';
      }

      // Inject images into the scrollable gallery div
      if (modalGallery) {
        modalGallery.innerHTML = galleryHTML;
        modalGallery.scrollLeft = 0; // Reset scroll position to the first image
      }

      // Metadata Injection
      const title = card.getAttribute('data-title') || '';
      const githubLink = card.getAttribute('data-link') || '#';
      const richDescription = card.querySelector('.hidden-full-desc')?.innerHTML || '';
      
      const videoBot = card.getAttribute('data-video-bot');
      const videoWeb = card.getAttribute('data-video-web');
      const defaultVideo = card.getAttribute('data-video') || videoBot || '';

      // Ecosystem Switcher (Bot/Web) Visibility
      if (ecosystemTabs) {
        ecosystemTabs.style.display = (videoBot && videoWeb) ? 'flex' : 'none';
      }

      // Text Injection
      if (modalTitle) modalTitle.textContent = title;
      if (modalDesc) modalDesc.innerHTML = richDescription;
      if (modalGithub) modalGithub.href = githubLink;

      // Video Source Handling
      if (modalVideoSource && modalVideo) {
        modalVideoSource.src = defaultVideo;
        modalVideo.load();
      }

      modal.showModal();
    });
  });

  // 3. HELPER FUNCTIONS (Using 'function' keyword for hoisting)
  function showView(type: 'video' | 'gallery') {
    if (type === 'video') {
        modalVideo?.classList.remove('hidden');
        modalGalleryContainer?.classList.add('hidden');
        showVideoBtn?.classList.add('bg-blue-600', 'text-white');
        showGalleryBtn?.classList.remove('bg-blue-600', 'text-white');
    } else {
        modalVideo?.classList.add('hidden');
        modalGalleryContainer?.classList.remove('hidden');
        showGalleryBtn?.classList.add('bg-blue-600', 'text-white');
        showVideoBtn?.classList.remove('bg-blue-600', 'text-white');
        if (modalVideo) modalVideo.pause();
    }
  }

  function scrollGallery(direction: 'next' | 'prev') {
    if (!modalGallery) return;
    const scrollAmount = modalGallery.clientWidth; 
    modalGallery.scrollBy({ 
        left: direction === 'next' ? scrollAmount : -scrollAmount, 
        behavior: 'smooth' 
    });
  }

  // 4. EVENT LISTENERS
  showVideoBtn?.addEventListener('click', () => showView('video'));
  showGalleryBtn?.addEventListener('click', () => showView('gallery'));
  prevBtn?.addEventListener('click', () => scrollGallery('prev'));
  nextBtn?.addEventListener('click', () => scrollGallery('next'));

  // Ecosystem Toggle Logic
  const ecoButtons = document.querySelectorAll('#ecosystem-tabs button');
  ecoButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      if (!activeCard || !modalVideo || !modalVideoSource) return;
      const type = btn.getAttribute('data-type');
      const videoSrc = activeCard.getAttribute(`data-video-${type}`);

      if (videoSrc) {
          showView('video'); // Swap back to video if they were in gallery
          modalVideoSource.src = videoSrc;
          modalVideo.load();
          modalVideo.play();

          ecoButtons.forEach(b => b.classList.remove('bg-white/40', 'text-white'));
          btn.classList.add('bg-white/40', 'text-white');
      }
    });
  });

  // Cleanup & Close
  const closeModal = () => {
      modal.close();
      if (modalVideo) modalVideo.pause();
  };

  closeButtons.forEach(btn => btn.addEventListener('click', closeModal));
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
</script>