---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Resume | Bryan Fung">
  <section class="py-24 pt-32 container mx-auto px-6 max-w-4xl">
    <div class="flex justify-between items-center mb-12">
      <h1 class="text-4xl font-black">Resume</h1>
      <a 
        href="/Bryan_Fung_Resume.pdf" 
        target="_blank" 
        class="px-6 py-3 bg-blue-600 text-white rounded-xl font-bold hover:bg-slate-900 transition-all shadow-lg flex items-center gap-2"
      >
        <i class='bx bxs-file-pdf text-xl'></i>
        Download PDF
      </a>
    </div>

    <div class="bg-white p-10 rounded-3xl border border-slate-100 shadow-sm">
        <h2 class="text-2xl font-bold text-blue-600 border-b pb-2 mb-4">Education</h2>
        <p class="font-bold">St. John's University <span class="float-right font-normal text-slate-500">2022 - 2026</span></p>
        <p class="mb-8">B.S. in Computer Science | GPA: 3.77</p>
        
        </div>
  </section>
</MainLayout>