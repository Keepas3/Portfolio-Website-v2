---
// src/components/Contact.astro
---

<section id="contact" class="py-24 bg-white">
    <div class="container mx-auto px-6 max-w-6xl">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
            
            <div class="reveal">
                <h2 class="text-4xl font-bold mb-6 text-slate-900">Let's Connect</h2>
                <p class="text-lg text-slate-600 mb-8 leading-relaxed">
                    I'm currently seeking **Software Engineering** opportunities for Summer/Fall 2026. 
                    Whether you have a question about my projects like <span class="text-blue-600 font-semibold">AdaptIQ</span> 
                     or just want to talk about chess, my inbox is always open.
                </p>
                
                <div class="space-y-6">
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center text-xl">
                            <i class='bx bx-envelope'></i>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 uppercase font-bold tracking-wider">Email</p>
                            <a href="mailto:bryanfung61@gmail.com" class="text-lg font-medium hover:text-blue-600 transition-colors">bryanfung61@gmail.com</a>
                        </div>
                    </div>
                    
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-12 bg-slate-50 text-slate-900 rounded-full flex items-center justify-center text-xl">
                            <i class='bx bxl-linkedin'></i>
                        </div>
                        <div>
                            <p class="text-sm text-slate-500 uppercase font-bold tracking-wider">LinkedIn</p>
                            <a href="https://www.linkedin.com/in/bryan-fung-a2a089256/" target="_blank" class="text-lg font-medium hover:text-blue-600 transition-colors">linkedin.com/in/bryan-fung</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="reveal bg-slate-50 p-8 rounded-3xl border border-slate-100 shadow-sm">
                <form action="https://formspree.io/f/your-id" method="POST" class="space-y-5">
                    <div>
                        <label for="name" class="block text-sm font-bold text-slate-700 mb-2">Full Name</label>
                        <input type="text" name="name" id="name" required 
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" 
                            placeholder="John Doe">
                    </div>
                    
                    <div>
                        <label for="email" class="block text-sm font-bold text-slate-700 mb-2">Email Address</label>
                        <input type="email" name="email" id="email" required 
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" 
                            placeholder="john@example.com">
                    </div>
                    
                    <div>
                        <label for="message" class="block text-sm font-bold text-slate-700 mb-2">Message</label>
                        <textarea name="message" id="message" rows="4" required 
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all resize-none" 
                            placeholder="Tell me about your project..."></textarea>
                    </div>
                    
                    <button type="submit" class="w-full py-4 bg-blue-600 text-white rounded-xl font-bold hover:bg-blue-700 shadow-lg shadow-blue-200 transition-all active:scale-95">
                        Send Message
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>