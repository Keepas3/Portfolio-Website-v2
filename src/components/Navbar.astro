---
// src/components/Navbar.astro
const navLinks = [
  { name: 'About', href: '/about' },
  { name: 'Projects', href: '/projects' },
  { name: 'Experience', href: '/experience' },
  { name: 'Education', href: '/education' },
  { name: 'Contact', href: '/contact' },
];
---

<nav id="navbar" class="fixed top-0 w-full z-[100] transition-all duration-500 transform -translate-y-full opacity-0 bg-white/80 backdrop-blur-md border-b border-slate-100 py-2">
    <div class="container mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-black text-slate-900 tracking-tighter">
            Bryan<span class="text-blue-600">Dev</span>
        </a>

        <div class="hidden md:flex items-center gap-8">
            {navLinks.map(link => (
                <a href={link.href} class="nav-link text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors uppercase tracking-widest">
                    {link.name}
                </a>
            ))}
            <a href="/Bryan_Fung_Resume.pdf" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2 bg-slate-900 text-white text-xs font-bold rounded-full hover:bg-blue-600 transition-all shadow-lg shadow-slate-200 group">
                RESUME
                <i class='bx bx-export text-sm group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform'></i>
            </a>
        </div>

        <button class="md:hidden text-3xl text-slate-900" id="menu-btn">
            <i class='bx bx-menu-alt-right'></i>
        </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-slate-100 p-6 flex flex-col gap-4 shadow-xl">
        {navLinks.map(link => (
            <a href={link.href} class="nav-link text-lg font-bold text-slate-900 py-2 border-b border-slate-50 last:border-0">
                {link.name}
            </a>
        ))}
    </div>
</nav>

<script>
    // 1. Select all links with the .nav-link class
    const navLinks = document.querySelectorAll('.nav-link');
    const navbar = document.getElementById('navbar') as HTMLElement;
    const menuBtn = document.getElementById('menu-btn') as HTMLButtonElement;
    const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;

    navLinks.forEach(link => {
        link.addEventListener('click', (e) => {
            const href = link.getAttribute('href'); // This will be "/projects"
            
            // For single-page scrolling, the ID on the page needs to match (e.g., id="projects")
            const targetId = href?.replace('/', ''); 
            const targetElement = document.getElementById(targetId || '');

            if (targetElement) {
                e.preventDefault(); // Stop the browser from actually changing pages

                // Update URL visually
                window.history.pushState({ section: targetId }, '', href || '/');

                // Scroll to the section
                targetElement.scrollIntoView({ behavior: 'smooth' });
                
                // If mobile menu is open, close it
                mobileMenu?.classList.add('hidden');
            }
        });
    });

    // 2. Scroll Effect (Show/Hide Navbar)
    window.addEventListener('scroll', () => {
        if (!navbar) return;
        if (window.scrollY > 150) {
            navbar.classList.remove('-translate-y-full', 'opacity-0');
            navbar.classList.add('translate-y-0', 'opacity-100');
        } else {
            navbar.classList.add('-translate-y-full', 'opacity-0');
            navbar.classList.remove('translate-y-0', 'opacity-100');
        }
    });

    // 3. Mobile Menu Toggle
    menuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
    });

    // 4. Handle Back/Forward Buttons
    window.addEventListener('popstate', (event) => {
        const sectionId = event.state?.section;
        if (sectionId) {
            document.getElementById(sectionId)?.scrollIntoView({ behavior: 'smooth' });
        } else {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    });
</script>