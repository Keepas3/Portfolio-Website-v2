<dialog id="project-modal" class="fixed inset-0 m-auto backdrop:bg-slate-900/90 backdrop:backdrop-blur-xl rounded-3xl shadow-[0_0_50px_rgba(0,0,0,0.5)] p-0 w-[95%] max-w-6xl overflow-hidden outline-none border border-white/10 bg-white">
    
    <div class="flex flex-col lg:flex-row h-full lg:h-[75vh]">
        
        <div class="w-full lg:w-[65%] bg-black flex items-center justify-center relative border-r border-slate-100">
            <div id="video-switcher" class="absolute top-4 left-4 z-20 flex gap-2">
        <button data-type="bot" class="video-tab-btn px-4 py-1.5 bg-white/20 backdrop-blur-md text-white text-xs font-bold rounded-lg border border-white/20 hover:bg-white/40 transition-all active-tab">
            Bot Demo
        </button>
        <button data-type="web" class="video-tab-btn px-4 py-1.5 bg-white/20 backdrop-blur-md text-white text-xs font-bold rounded-lg border border-white/20 hover:bg-white/40 transition-all">
            Website Demo
        </button>
    </div>
            <video 
                id="modal-video" 
                class="w-full h-full max-h-full object-contain shadow-2xl" 
                controls 
                autoplay 
                muted 
                loop 
                playsinline
            >
                <source src="" type="video/mp4">
            </video>
            
            <button class="close-modal lg:hidden absolute top-4 right-4 bg-black/50 p-2 rounded-full text-white backdrop-blur-md">
                <i class='bx bx-x text-2xl'></i>
            </button>
        </div>

        <div class="w-full lg:w-[35%] p-8 lg:p-10 flex flex-col bg-white">
            <div class="flex justify-between items-start mb-6">
                <div>
                    <h2 id="modal-title" class="text-3xl font-black text-slate-900 tracking-tight leading-tight"></h2>
                    <div id="modal-award-container" class="mt-2"></div>
                </div>
                <button class="close-modal hidden lg:block text-slate-400 hover:text-slate-900 transition-colors p-1">
                    <i class='bx bx-x text-4xl'></i>
                </button>
            </div>

            <div class="flex-grow overflow-y-auto pr-2 custom-scrollbar">
                <p id="modal-description" class="text-slate-600 leading-relaxed whitespace-pre-line text-sm"></p>
            </div>
            
            <div class="mt-8 pt-6 border-t border-slate-100">
                <a id="modal-github" href="#" target="_blank" class="flex items-center justify-center gap-2 py-4 bg-slate-900 text-white rounded-2xl font-bold hover:bg-blue-600 transition-all shadow-lg hover:shadow-blue-200">
                    <i class='bx bxl-github text-xl'></i> View Source Code
                </a>
            </div>
        </div>
    </div>
</dialog>

<style>
    /* Ensure the dialog stays centered and animates like a folder opening */
    dialog {
        opacity: 0;
        transform: scale(0.9) translateY(30px);
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    dialog[open] {
        opacity: 1;
        transform: scale(1) translateY(0);
    }

    /* Standard Dialog Centering Fix */
    dialog::backdrop {
        /* 40% opacity allows the portfolio content to stay visible */
        background: rgba(15, 23, 42, 0.4); 
        /* The blur creates the "Glass" effect */
        backdrop-filter: blur(12px); 
    }

    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
</style>